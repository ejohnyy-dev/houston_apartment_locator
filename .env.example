# ============================================================================
# Houston Apartment Locator — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the required values
# See AUTOMATION_SETUP.md for detailed configuration guide

# ============================================================================
# REQUIRED: RentCast API Integration
# ============================================================================
# Get your API key from: https://www.rentcast.io/
# Format: 32-character hexadecimal string
RENTCAST_API_KEY=your_32_char_hex_key_here

# Monthly request limit (default: 50)
# RentCast API calls are counted against this limit
RENTCAST_MONTHLY_REQUEST_LIMIT=50

# Cache TTL in hours (default: 24)
# How long to keep cached apartment data before refreshing
RENTCAST_CACHE_TTL_HOURS=24

# Batch size for refresh operations (default: 50)
# Number of properties to fetch per refresh cycle
RENTCAST_REFRESH_BATCH_SIZE=50

# ============================================================================
# REQUIRED: HubSpot Integration
# ============================================================================
# Get your token from: https://app.hubspot.com/l/private-apps
# Format: "pat-" followed by a long string
HUBSPOT_PRIVATE_APP_TOKEN=pat_your_token_here

# ============================================================================
# OPTIONAL: Google Sheets Integration
# ============================================================================
# Set this to enable lead capture to Google Sheets
# Should be a webhook URL from Apps Script or Zapier
# Leave blank to disable
GOOGLE_SHEETS_ENDPOINT=https://your-webhook-url-here

# ============================================================================
# OPTIONAL: Manus Heartbeat (Scheduled Tasks)
# ============================================================================
# These are set automatically by the deployment platform
# Only needed for local development with heartbeat features
# BUILT_IN_FORGE_API_URL=https://api.manus.im
# BUILT_IN_FORGE_API_KEY=your_key_here

# ============================================================================
# OPTIONAL: Database Configuration
# ============================================================================
# MySQL/TiDB connection string for storing inquiries and users
# Leave blank to disable database features
# DATABASE_URL=mysql://user:password@host:port/database

# ============================================================================
# OPTIONAL: Manus OAuth Configuration
# ============================================================================
# For user authentication via Manus
# MANUS_OAUTH_CLIENT_ID=your_client_id
# MANUS_OAUTH_CLIENT_SECRET=your_client_secret

# ============================================================================
# OPTIONAL: Development Settings
# ============================================================================
# Node environment (development or production)
NODE_ENV=development

# Server port
PORT=3000

# ============================================================================
# Property Database Configuration
# ============================================================================
# Path to property CSV file (default: data/property_data_final.csv)
# PROPERTY_DATABASE_CSV=data/property_data_final.csv

# Path to property photo manifest (default: data/property-photo-manifest.json)
# PROPERTY_PHOTO_MANIFEST=data/property-photo-manifest.json

# Path to RentCast target CSV (optional, for custom address lists)
# RENTCAST_TARGET_CSV=data/rentcast-targets.csv

# ============================================================================
# File Paths (usually don't need to change)
# ============================================================================
# RENTCAST_CACHE_FILE=server/data/rentcast-cache.json
# RENTCAST_USAGE_FILE=server/data/rentcast-usage.json
CRM_API_URL=https://wallpapers-transmitted-friends-molecular.trycloudflare.com
